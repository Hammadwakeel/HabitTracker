{
  "expo": {
    "name": "Life OS",
    "slug": "life-os",
    "version": "6.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0D0F14",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.lifeos",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to get accurate prayer times for your location.",
        "NSPhotoLibraryUsageDescription": "Used to set your profile picture.",
        "NSCameraUsageDescription": "Used to take your profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0F14"
      },
      "package": "com.yourname.lifeos",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#6C63FF"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Life OS to use your location for accurate prayer times."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Life OS to access your photos to set a profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "eba64a32-4bc5-46ae-82fe-6b383ddea2de"
      }
    }
  }
}
